# E-posta doğrulama (EmailJS - ücretsiz tier: https://www.emailjs.com/)
# Kayıt olurken kullanıcıya gönderilecek 6 haneli kod için gerekli.
# Hesap oluşturup Service + Email Template ekleyin; şablonda {{to_email}} ve {{code}} kullanın.
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id

# Şifre sıfırlama: EmailJS’te ayrı bir şablon oluşturun; {{to_email}} ve {{reset_link}} kullanın.
# Bağlantı, kullanıcıyı /sifre-yenile?token=... sayfasına yönlendirir.
VITE_EMAILJS_TEMPLATE_ID_RESET=your_password_reset_template_id

# Destek hattı e-postası (İletişim, footer, geri bildirim metinleri). Boş bırakılırsa diapalorg@gmail.com kullanılır.
VITE_SUPPORT_EMAIL=diapalorg@gmail.com
